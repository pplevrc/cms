{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": ["node_modules"]
  },
  "permissions": {
    "deny": [
      "Bash(gh pr merge*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin main*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)"
    ]
  }
}
