{
  "name": "cms-repo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "secretlint": "secretlint --maskSecrets '**/*'",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck",
    "lint": "pnpm -r --workspace-concurrency=1 run lint",
    "test:int": "pnpm -r --workspace-concurrency=1 run test:int",
    "test:e2e": "pnpm -r --workspace-concurrency=1 run test:e2e"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "secretlint": "^13.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
