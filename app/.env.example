# 値の出処・想定レンジは designs/private/templates/env-vars-reference.md (gitignored) を参照。
# 認証パラメータの具体値は designs/private/auth-parameters.md を参照。

# ==== Payload core (必須) ====
DATABASE_URL=
# 32+ chars random。生成例: openssl rand -base64 32
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=
COOKIE_DOMAIN=
ALLOWED_ORIGINS=

# ==== 認証パラメータ ====
AUTH_TOKEN_EXPIRATION_SEC=
AUTH_MAX_LOGIN_ATTEMPTS=
AUTH_LOCK_TIME_MS=
AUTH_PASSWORD_MIN_LENGTH=
RATE_LIMIT_LOGIN_MAX=
RATE_LIMIT_LOGIN_WINDOW_MS=

# ==== Upload (Media collection) ====
UPLOAD_MAX_FILE_SIZE_BYTES=
# カンマ区切り (例: image/png,image/jpeg,image/webp)
UPLOAD_ALLOWED_MIMETYPES=

# ==== Storage (S3 互換オブジェクトストレージ) ====
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=
MEDIA_PUBLIC_URL=

# ==== Mail (SMTP) ====
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
